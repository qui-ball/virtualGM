# Frontend (Vite) – copy to .env or .env.local in this directory for overrides
# Variables must be prefixed with VITE_ to be exposed to the client.
#
# Mode-specific files (all gitignored): .env.development (npm run dev), .env.production (npm run build)

# Backend API base URL. Use for all API requests to the Virtual GM API.
# Default: http://localhost:8000
# On a physical device (browser on phone/tablet), set to your host machine IP, e.g.:
# VITE_API_URL=http://192.168.1.10:8000
VITE_API_URL=http://localhost:8000

# Supabase (client only — publishable key; see Supabase docs for publishable vs legacy anon)
# Dashboard: Project Settings → API Keys → Publishable key (sb_publishable_...)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_ANON_KEY=
