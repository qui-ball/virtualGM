# Frontend Environment Variables Example
# Copy this file to .env, .env.development, or .env.production based on your needs

# =============================================================================
# API Configuration
# =============================================================================

# Backend API URL
# For web development: http://localhost:8000
# For Docker: http://localhost:8000
# For production: https://api.virtualgm.com
# For mobile development: Use your local IP (e.g., http://192.168.1.100:8000)
VITE_API_URL=http://localhost:8000

# =============================================================================
# Capacitor Configuration
# =============================================================================

# Development server URL for Capacitor live reload
# Set to your local IP address when testing on physical devices
# Example: http://192.168.1.100:5173
# Leave empty for production builds
VITE_CAPACITOR_DEV_SERVER_URL=

# Enable cleartext (HTTP) for Android development
# Set to 'true' if using HTTP (not HTTPS) for development
VITE_CAPACITOR_CLEARTEXT=false

# =============================================================================
# Application Configuration
# =============================================================================

# Application environment
# Options: development, staging, production
VITE_APP_ENV=development

# Application name (displayed in UI)
VITE_APP_NAME=Virtual GM

# =============================================================================
# Feature Flags (when implemented)
# =============================================================================

# Enable/disable features
# VITE_FEATURE_ANALYTICS=false
# VITE_FEATURE_DEBUG_MODE=false
