# Template for production builds (copy to `.env.production`, which is gitignored).
# CI/CD: set the same variables as encrypted secrets and export them before `vite build`
# (or write a short-lived .env.production in the pipeline).

# Public API origin for the Virtual GM backend (no trailing slash). If unset, the app defaults
# to http://localhost:8000 — wrong for a hosted SPA; always set this in real deployments.
# VITE_API_URL=https://api.example.com

# Hosted Supabase — Project Settings → API (project URL + publishable key only)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
