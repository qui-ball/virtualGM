# Virtual GM – environment template
# Copy to .env and fill in values. Do not commit .env.
# For Docker: docker-compose.yml loads .env.docker then .env.development (gitignored).
# Put secrets in .env.development; keep .env.docker for non-secret overrides only.
# Production template (committed): .env.production.example → copy to gitignored .env.production

# ---------- Backend ----------
# Runtime: development | production
ENV=development

# Logging: DEBUG | INFO | WARNING | ERROR
LOGURU_LEVEL=INFO

# Logfire (optional): set LOGFIRE_TOKEN to enable observability
# LOGFIRE_TOKEN=
# LOGFIRE_ENVIRONMENT=development

# LLM API keys (set one or more depending on which provider you use)
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=

# ---------- Supabase (backend only) ----------
# Use in root .env.development or .env.docker — never commit real keys.
# Secret key (sb_secret_...) or legacy service_role: server-side only, bypasses RLS.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ---------- Frontend (Vite) ----------
# Backend API base URL (used when frontend calls the API)
# Default for local dev: http://localhost:8000
# On a physical device, use host machine IP, e.g. http://192.168.1.10:8000
# VITE_API_URL=http://localhost:8000
