# virtualGM Backend Environment Variables Example
# Copy this file to .env and fill in your actual values
#
# NOTE: Frontend environment variables are managed separately in frontend/.env files
# See frontend/.env.example for frontend-specific configuration
#
# For Docker-specific overrides, use .env.docker

# =============================================================================
# Backend Configuration
# =============================================================================

# Logfire Observability (Optional)
# Get your token from https://logfire.pydantic.dev
# If not set, Logfire will be disabled
LOGFIRE_TOKEN=
LOGFIRE_ENVIRONMENT=development

# Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOGURU_LEVEL=INFO

# OpenRouter API Key (Required for LLM functionality)
# Get your API key from https://openrouter.ai
# This is required for the game master agent to function
OPENROUTER_API_KEY=

# =============================================================================
# Frontend Configuration
# =============================================================================

# Frontend environment variables are managed separately in frontend/.env files
# See frontend/.env.example for frontend-specific variables
# Frontend variables are loaded by Vite and Capacitor during build/runtime

# =============================================================================
# Docker-Specific Configuration
# =============================================================================

# These variables are typically set in .env.docker or docker-compose.yml
# They control Docker-specific behavior and don't need to be set for local dev

# =============================================================================
# Future Services (Placeholders)
# =============================================================================

# Supabase Configuration (when implemented)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Database Configuration (when implemented)
# DATABASE_URL=
# DB_HOST=
# DB_PORT=
# DB_NAME=
# DB_USER=
# DB_PASSWORD=
