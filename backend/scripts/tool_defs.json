[
  {
    "type": "function",
    "function": {
      "name": "narrate",
      "description": "Show text to the player. This is the ONLY way to communicate with the player \u2014 anything not passed through narrate() is invisible to them.",
      "parameters": {
        "additionalProperties": false,
        "properties": {
          "text": {
            "description": "ALL player-facing content: narration, dialogue, scene descriptions, and questions.",
            "type": "string"
          }
        },
        "required": [
          "text"
        ],
        "type": "object"
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "load_campaign_section",
      "description": "Load a campaign section into context. See the campaign index for available section paths.",
      "parameters": {
        "additionalProperties": false,
        "properties": {
          "section": {
            "description": "Section path from the campaign index (e.g., \"Part1_Goblin_Arrows/Goblin_Ambush\")",
            "type": "string"
          }
        },
        "required": [
          "section"
        ],
        "type": "object"
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "unload_campaign_section",
      "description": "Remove a campaign section from context to free a slot.",
      "parameters": {
        "additionalProperties": false,
        "properties": {
          "section": {
            "description": "Section path to unload",
            "type": "string"
          }
        },
        "required": [
          "section"
        ],
        "type": "object"
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "roll_dice",
      "description": "Roll dice and return the result.",
      "parameters": {
        "additionalProperties": false,
        "properties": {
          "dice_count": {
            "description": "Number of dice to roll",
            "type": "integer"
          },
          "dice_type": {
            "description": "Type of die (d4, d6, d8, d10, d12, d20, d100)",
            "enum": [
              "d4",
              "d6",
              "d8",
              "d10",
              "d12",
              "d20",
              "d100"
            ],
            "type": "string"
          },
          "advantage": {
            "default": false,
            "description": "If True and rolling d20, roll 2d20 and take higher",
            "type": "boolean"
          },
          "disadvantage": {
            "default": false,
            "description": "If True and rolling d20, roll 2d20 and take lower",
            "type": "boolean"
          }
        },
        "required": [
          "dice_count",
          "dice_type"
        ],
        "type": "object"
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "ask_player_roll",
      "description": "Request the player to roll dice. Defers execution until the player provides their result.",
      "parameters": {
        "additionalProperties": false,
        "properties": {
          "dice_count": {
            "description": "Number of dice to roll",
            "type": "integer"
          },
          "dice_type": {
            "description": "Type of die (d4, d6, d8, d10, d12, d20, d100)",
            "enum": [
              "d4",
              "d6",
              "d8",
              "d10",
              "d12",
              "d20",
              "d100"
            ],
            "type": "string"
          },
          "purpose": {
            "description": "Brief description of what the roll is for (e.g., \"attack roll\", \"damage\", \"Wit check\")",
            "type": "string"
          }
        },
        "required": [
          "dice_count",
          "dice_type",
          "purpose"
        ],
        "type": "object"
      }
    }
  },
  {
    "type": "function",
    "function": {
      "name": "create_enemy",
